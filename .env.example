RECAPTCHA_SECRET_KEY="your_recaptcha_secret_key_here"

# ============================================================
# [DATABASE] PRISMA POSTGRESQL
# ============================================================
# Chuỗi kết nối Database (ví dụ từ Neon.tech hoặc Supabase)
DATABASE_URL="postgres://user:password@your-host.aivencloud.com:25038/defaultdb?sslmode=require"

# ============================================================
# [RATE LIMITING] UPSTASH REDIS
# ============================================================
# Tạo tại: https://console.upstash.com/
# Nếu để trống, rate limiting sẽ bị bypass (chỉ chấp nhận cho development).
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token_here"

