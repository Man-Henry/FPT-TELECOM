# ============================================================
# Environment Variables for FPT Telecom Website
# ============================================================
# Copy file này thành .env.local và điền giá trị thật.
# KHÔNG commit .env hoặc .env.local lên Git!
# ============================================================

# ============================================================
# [SITE CONFIG] Thông tin hiển thị trên website
# ============================================================
NEXT_PUBLIC_APP_URL="https://fpt-telecom.vn"
NEXT_PUBLIC_APP_NAME="FPT Telecom"
NEXT_PUBLIC_HOTLINE="0888.888.888"
NEXT_PUBLIC_ADDRESS="Số 123, Đường ABC, Quận XYZ, TP.HCM"
NEXT_PUBLIC_ZALO_OA_URL="https://zalo.me/1234567890"
NEXT_PUBLIC_TELEGRAM_URL="https://t.me/fpt_telecom_bot"
NEXT_PUBLIC_FACEBOOK_URL="https://facebook.com/fpttelecom"
NEXT_PUBLIC_YOUTUBE_URL="https://youtube.com/@fpttelecom"
NEXT_PUBLIC_TIKTOK_URL="https://tiktok.com/@fpttelecom"
NEXT_PUBLIC_EMAIL="hotro@fpt-telecom.vn"

# ============================================================
# [MANDATORY] TELEGRAM BOT — Nhận thông báo Lead
# ============================================================
# 1. Chat với @BotFather trên Telegram để tạo Bot và lấy Token
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# 2. Chat với @userinfobot hoặc lấy ID nhóm để điền vào đây
# (ID nhóm thường có dấu trừ ở đầu, vd: -1001234567890)
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# ============================================================
# [SECURITY] GOOGLE RECAPTCHA v3
# ============================================================
# Đăng ký tại: https://www.google.com/recaptcha/admin/create
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your_recaptcha_site_key_here"
RECAPTCHA_SECRET_KEY="your_recaptcha_secret_key_here"

# ============================================================
# [DATABASE] PRISMA POSTGRESQL
# ============================================================
# Chuỗi kết nối Database (ví dụ từ Neon.tech hoặc Supabase)
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# ============================================================
# [RATE LIMITING] UPSTASH REDIS
# ============================================================
# Tạo tại: https://console.upstash.com/
# Nếu để trống, rate limiting sẽ bị bypass (chỉ chấp nhận cho development).
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token_here"

# ============================================================
# [ANALYTICS] Tracking & Monitoring (Optional)
# ============================================================
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_CLARITY_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ============================================================
# [MONITORING] Error Tracking (Optional)
# ============================================================
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
RESEND_API_KEY=""
NOTIFICATION_EMAIL=""
