# ============================================================
# FPT Telecom — Environment Variables Template
# ============================================================
# Copy file này thành .env.local để sử dụng trong development:
#   cp .env.example .env.local
#
# ⚠️  KHÔNG commit .env.local hoặc .env.production lên Git!
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="FPT Telecom"
NEXT_PUBLIC_APP_DESCRIPTION="Lắp mạng FPT - Internet cáp quang, Truyền hình, Camera"

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Zalo OA ---
ZALO_OA_ID=
ZALO_OA_SECRET=

# --- reCAPTCHA v3 ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Database (Neon / Supabase) ---
DATABASE_URL=

# --- Email Notification (Resend) ---
RESEND_API_KEY=
NOTIFICATION_EMAIL=

# --- Analytics ---
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# --- Sentry ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
